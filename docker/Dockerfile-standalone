FROM ubuntu:22.04

WORKDIR /app/

ENV INSTALL=native NATIVE=true

LABEL MAINTAINER="Har01d"

RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apt-get update && apt-get install -y --no-install-recommends \
        openjdk-17-jre-headless \
        unzip \
        wget \
        sqlite3 \
        nginx \
        busybox \
        curl \
        ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/* && \
    mkdir -p /opt/atv/data /opt/atv/log \
             /opt/alist/data \
             /etc/nginx/http.d \
             /data/index && \
    mkdir -p /jre/bin && ln -s /usr/bin/java /jre/bin/java && \
    ln -sf $(which busybox) /bin/busybox-extras

WORKDIR /opt/atv/

# 2. 拷贝配置文件和脚本
COPY config/alist.json /
COPY scripts/index.sh /
COPY entrypoint-standalone.sh /entrypoint.sh
COPY init-standalone.sh /init.sh

# 3. 拷贝数据文件 [cite: 5]
COPY data/update.sql /
COPY data/tvbox.zip /
COPY data/index.share.zip /
COPY data/cat.zip /
COPY data/pg.zip /
COPY data/zx.zip /
COPY data/data.zip /
COPY data/base_version /
COPY data/version /app_version

# 4. 拷贝 Java 应用 [cite: 5]
COPY target/atv ./
COPY scripts/h2-2.3.232.jar /h2.jar

RUN chmod +x /entrypoint.sh

EXPOSE 4567

ENTRYPOINT ["/entrypoint.sh"]
CMD ["--spring.profiles.active=standalone"]