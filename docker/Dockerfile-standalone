FROM ubuntu:22.04

WORKDIR /app/

RUN apt-get update && apt-get install -y \
    curl \
    wget \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/install.sh ./

RUN bash install.sh

ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8
ENV TOOLCHAIN_DIR=/opt/musl
ENV CC="$TOOLCHAIN_DIR/bin/gcc"
ENV MAVEN_HOME=/opt/maven
ENV JAVA_HOME=/opt/graalvm
ENV GRAALVM_HOME=/opt/graalvm
ENV PATH="${JAVA_HOME}/bin:${MAVEN_HOME}/bin:$TOOLCHAIN_DIR/bin:${PATH}"

ENV INSTALL=native NATIVE=true

LABEL MAINTAINER="Har01d"

RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    mkdir -p /opt/atv/data /opt/atv/log

WORKDIR /opt/atv/

# 2. 拷贝配置文件和脚本
COPY config/alist.json /
COPY scripts/index.sh /
COPY entrypoint-standalone.sh /entrypoint.sh
COPY init.sh /

# 3. 拷贝数据文件 [cite: 5]
COPY data/update.sql /
COPY data/tvbox.zip /
COPY data/index.share.zip /
COPY data/cat.zip /
COPY data/pg.zip /
COPY data/zx.zip /
COPY data/data.zip /
COPY data/base_version /
COPY data/version /app_version

# 4. 拷贝 Java 应用 [cite: 5]
COPY target/atv ./

RUN chmod +x /entrypoint.sh

EXPOSE 4567

ENTRYPOINT ["/entrypoint.sh"]
CMD ["--spring.profiles.active=standalone"]